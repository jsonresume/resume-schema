{
  "name": "@jsonresume/schema",
  "version": "1.1.2",
  "description": "JSON Resume Schema",
  "private": false,
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./index.mjs"
    },
    "./validate": "./validate.mjs",
    "./schemas/resume.json": "./schema.json",
    "./schemas/job.json": "./job-schema.json"
  },
  "scripts": {
    "build": "node tools/build.mjs",
    "test": "npm run validate && npm run test-units",
    "validate": "ajv validate -s node_modules/json-metaschema/draft-07-schema -d schema",
    "test-units": "tape **/*.spec.js **/*.spec.cjs **/*.spec.mjs | tap-spec",
    "preversion": "npm test",
    "postversion": "git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/jsonresume/resume-schema.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jsonresume/resume-schema/issues"
  },
  "files": [
    "dist/resume-validator.mjs",
    "dist/index.cjs",
    "index.mjs",
    "validate.mjs",
    "sample.resume.json",
    "sample.job.json",
    "schema.json",
    "job-schema.json"
  ],
  "dependencies": {
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-cli": "^3.3.0",
    "esbuild": "^0.28.0",
    "json-metaschema": "^1.3.0",
    "tap-spec": "^5.0.0",
    "tape": "^4.16.2"
  },
  "engines": {
    "node": ">=20"
  }
}
